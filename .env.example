# Flask environment
FLASK_ENV=development
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
SECRET_KEY=change-this-secret
JWT_SECRET_KEY=change-this-jwt-secret

# Database
DATABASE_URL=sqlite:///instance/expense_tracker.db

# CORS
CORS_ORIGINS=http://localhost:5173

# JWT expiration
JWT_ACCESS_HOURS=1
JWT_REFRESH_DAYS=30
