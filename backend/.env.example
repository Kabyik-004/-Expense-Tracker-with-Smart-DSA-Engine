# ─── Flask ───────────────────────────────────────
SECRET_KEY=change-this-to-a-random-64-char-string
FLASK_ENV=production

# ─── Database ────────────────────────────────────
# SQLite (dev):  sqlite:///instance/expense_tracker.db
# PostgreSQL:    postgresql://user:password@host:5432/expense_tracker
DATABASE_URL=sqlite:///instance/expense_tracker.db

# ─── JWT ─────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-different-random-64-char-string
JWT_ACCESS_HOURS=1
JWT_REFRESH_DAYS=30

# ─── CORS ────────────────────────────────────────
CORS_ORIGINS=https://your-domain.com

# ─── Gunicorn (optional overrides) ───────────────
# GUNICORN_WORKERS=4
# GUNICORN_BIND=0.0.0.0:8000

# ─── Token blocklist ─────────────────────────────
JWT_BLOCKLIST_ENABLED=true

# ─── Email / SMTP ────────────────────────────────
# For Gmail, use an App Password (not your regular password):
#   https://myaccount.google.com/apppasswords
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_USE_TLS=true
MAIL_DEFAULT_SENDER=

# ─── OTP / Security ──────────────────────────────
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_COOLDOWN_SECONDS=60
OTP_RESEND_COOLDOWN=60
OTP_RATE_LIMIT_WINDOW=60
OTP_RATE_LIMIT_MAX=5
