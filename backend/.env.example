# ─── Flask ───────────────────────────────────────
SECRET_KEY=your-secret-key-here
FLASK_ENV=development

# ─── Database ────────────────────────────────────
DATABASE_URL=sqlite:///instance/expense_tracker.db

# ─── JWT ─────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ACCESS_HOURS=1
JWT_REFRESH_DAYS=30

# ─── CORS ────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173
