{
  "info": {
    "name": "Expense Tracker - Auth API",
    "description": "Complete authentication API endpoints for the Expense Tracker with Smart DSA Engine",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000/api"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "refresh_token",
      "value": ""
    },
    {
      "key": "reset_token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Public Endpoints",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('access_token', json.data.access_token);",
                  "    pm.collectionVariables.set('refresh_token', json.data.refresh_token);",
                  "    pm.test('Registration successful', function() {",
                  "        pm.expect(json.success).to.be.true;",
                  "        pm.expect(json.data.user).to.have.property('id');",
                  "        pm.expect(json.data.user).to.have.property('username');",
                  "        pm.expect(json.data.user).to.not.have.property('password_hash');",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"john_doe\",\n    \"email\": \"john@example.com\",\n    \"password\": \"SecurePass1\",\n    \"full_name\": \"John Doe\",\n    \"currency\": \"INR\"\n}"
            },
            "url": "{{base_url}}/auth/register",
            "description": "Create a new user account. Returns JWT tokens."
          }
        },
        {
          "name": "Register - Validation Error",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"ab\",\n    \"email\": \"not-an-email\",\n    \"password\": \"weak\"\n}"
            },
            "url": "{{base_url}}/auth/register",
            "description": "Test validation errors — short username, invalid email, weak password."
          }
        },
        {
          "name": "Login (with email)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('access_token', json.data.access_token);",
                  "    pm.collectionVariables.set('refresh_token', json.data.refresh_token);",
                  "    pm.test('Login successful', function() {",
                  "        pm.expect(json.success).to.be.true;",
                  "        pm.expect(json.data.access_token).to.be.a('string');",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"login\": \"john@example.com\",\n    \"password\": \"SecurePass1\"\n}"
            },
            "url": "{{base_url}}/auth/login",
            "description": "Authenticate with email + password."
          }
        },
        {
          "name": "Login (with username)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('access_token', json.data.access_token);",
                  "    pm.collectionVariables.set('refresh_token', json.data.refresh_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"login\": \"john_doe\",\n    \"password\": \"SecurePass1\"\n}"
            },
            "url": "{{base_url}}/auth/login",
            "description": "Authenticate with username + password."
          }
        },
        {
          "name": "Login - Invalid Credentials",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"login\": \"john@example.com\",\n    \"password\": \"WrongPassword1\"\n}"
            },
            "url": "{{base_url}}/auth/login",
            "description": "Test invalid credentials response."
          }
        },
        {
          "name": "Forgot Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    if (json.data && json.data.reset_token) {",
                  "        pm.collectionVariables.set('reset_token', json.data.reset_token);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"john@example.com\"\n}"
            },
            "url": "{{base_url}}/auth/forgot-password",
            "description": "Request a password reset token."
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"token\": \"{{reset_token}}\",\n    \"new_password\": \"NewSecure1\"\n}"
            },
            "url": "{{base_url}}/auth/reset-password",
            "description": "Reset password using the token from forgot-password."
          }
        }
      ]
    },
    {
      "name": "Protected Endpoints",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/auth/profile",
            "description": "Get the authenticated user's profile."
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"full_name\": \"John Updated\",\n    \"currency\": \"USD\"\n}"
            },
            "url": "{{base_url}}/auth/profile",
            "description": "Update profile fields."
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"current_password\": \"SecurePass1\",\n    \"new_password\": \"NewSecure1\"\n}"
            },
            "url": "{{base_url}}/auth/change-password",
            "description": "Change password (requires current password)."
          }
        },
        {
          "name": "Validate Token",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/auth/validate",
            "description": "Check if the current JWT is valid."
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('access_token', json.data.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{refresh_token}}" }
            ],
            "url": "{{base_url}}/auth/refresh",
            "description": "Get a new access token using the refresh token."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/auth/logout",
            "description": "Logout (client-side token discard)."
          }
        }
      ]
    },
    {
      "name": "Error Cases",
      "item": [
        {
          "name": "Access Protected Route Without Token",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/auth/profile",
            "description": "Should return 401 — Authorization token is missing."
          }
        },
        {
          "name": "Access With Invalid Token",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer invalid.token.here" }
            ],
            "url": "{{base_url}}/auth/profile",
            "description": "Should return 401 — Invalid token."
          }
        },
        {
          "name": "Register Duplicate Username",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"john_doe\",\n    \"email\": \"different@example.com\",\n    \"password\": \"SecurePass1\"\n}"
            },
            "url": "{{base_url}}/auth/register",
            "description": "Should return 409 — Username already taken."
          }
        }
      ]
    }
  ]
}
